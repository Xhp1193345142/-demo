DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost,testserver
DJANGO_CORS_ALLOWED_ORIGINS=http://127.0.0.1:3000,http://localhost:3000,http://127.0.0.1:3001,http://localhost:3001
DJANGO_CSRF_TRUSTED_ORIGINS=http://127.0.0.1:3000,http://localhost:3000,http://127.0.0.1:3001,http://localhost:3001

# 本地如使用 Buyu 专属 PostgreSQL 容器，请按以下默认值填写；留空则回退到 SQLite。
POSTGRES_DB=buyu
POSTGRES_USER=buyu_user
POSTGRES_PASSWORD=buyu_password
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5433
